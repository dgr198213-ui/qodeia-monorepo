{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "hooks/*": ["./src/hooks/*"],
      "components/*": ["./src/components/*"],
      "services/*": ["./src/services/*"],
      "utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*", "*.ts", "*.js", "vite-plugins/**/*"],
  // components/ y hooks/ (raíz) están excluidos: es código muerto no importado
  // desde src/ que depende de "@qodeia/agent-sdk", un paquete inexistente en el
  // workspace. Eliminar o reescribir antes de reincorporarlos.
  "exclude": ["node_modules", "dist", "components", "hooks", "lib"]
}
