{
  "name": "qodeia-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "turbo format",
    "format:check": "turbo format --dry-run",
    "deps:update": "pnpm -r exec npm-check-updates -u",
    "deps:check": "pnpm -r exec npm-check-updates --depth=0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "npm-check-updates": "^17.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "pnpm-store": "link:/tmp/pnpm-store"
  }
}