{
  "name": "@qodeia/ui",
  "version": "0.1.0",
  "description": "Componentes UI compartidos para QodeIA",
  "private": false,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "type": "module",
